#!/usr/bin/env sh
# rig-managed-hook: pre-push (#298)
#
# Applies the acceptance-gate's *computational* sensor (secret-pattern scan)
# to every push, whether or not the commit went through /rig:rig. This is a
# deliberately small slice of the gate: build/lint/test commands are
# project-specific and rig has no way to know them from a plain git hook, so
# this hook only covers what can be checked mechanically without any project
# configuration — matching `no_secret_leak`, not the full acceptance-gate.
#
# Opt-in only: installed via `python3 scripts/workbench.py install-git-hook`,
# which refuses to silently overwrite a hook it did not install itself.
#
# git invokes pre-push with: <remote name> <remote url>
# and feeds ref updates on stdin as lines of:
#   <local ref> <local sha1> <remote ref> <remote sha1>
set -eu

ZERO_SHA="0000000000000000000000000000000000000000"

# Common leaked-secret shapes: cloud provider keys, private key blocks, and
# well-known vendor token prefixes (GitHub/OpenAI/Slack). Intentionally
# conservative — false negatives are expected; this is a mechanical
# tripwire, not a substitute for the AI-judged `no_secret_leak` criterion.
PATTERN='-----BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----|[Aa][Ww][Ss][A-Za-z_]*(SECRET|secret)[A-Za-z_]*[[:space:]]*[=:][[:space:]]*[A-Za-z0-9/+=]{20,}|(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{30,}|sk-[A-Za-z0-9]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}'

found=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$ZERO_SHA" ] && continue   # deleting a remote ref, nothing to scan

  if [ "${remote_sha:-$ZERO_SHA}" = "$ZERO_SHA" ]; then
    # New remote branch: no known base to diff against. Bound the scan to
    # the last 200 commits reachable from local_sha rather than the full
    # history, so an initial push of a large existing repo doesn't hang.
    range_desc="$local_ref (new branch, last 200 commits)"
    hits=$(git log -p --max-count=200 "$local_sha" 2>/dev/null | grep -nE -e "$PATTERN" || true)
  else
    range_desc="$local_ref ($remote_sha..$local_sha)"
    hits=$(git diff "$remote_sha..$local_sha" 2>/dev/null | grep -nE -e "$PATTERN" || true)
  fi

  if [ -n "$hits" ]; then
    found=1
    echo "[rig pre-push] possible secret pattern in $range_desc:" >&2
    echo "$hits" | head -20 >&2
  fi
done

if [ "$found" -eq 1 ]; then
  echo "" >&2
  echo "[rig pre-push] push blocked — possible secret detected (mechanical pattern match, not the full acceptance-gate)." >&2
  echo "[rig pre-push] false positive? re-run with: git push --no-verify" >&2
  exit 1
fi
exit 0
