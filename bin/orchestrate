#!/usr/bin/env sh
# rig orchestrate — wrapper that uses Claude Code's automatic plugin bin/ PATH
# addition so scripts/orchestrate.py can be called regardless of cwd.
#   - Uses $RIG_HOME if it is set.
#   - Otherwise resolves symlinks via realpath to locate the rig checkout.
set -e
if [ -n "${RIG_HOME:-}" ] && [ -f "$RIG_HOME/scripts/orchestrate.py" ]; then
  exec python3 "$RIG_HOME/scripts/orchestrate.py" "$@"
fi
SELF="$(readlink -f -- "$0" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$0")"
RIG_HOME_DETECTED="$(cd "$(dirname "$SELF")/.." && pwd)"
exec python3 "$RIG_HOME_DETECTED/scripts/orchestrate.py" "$@"
